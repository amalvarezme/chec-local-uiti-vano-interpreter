# ==========================================
# LLM CONFIGURATION
# ==========================================
# Note: You only need to configure ONE of the options below.
# Uncomment the block you wish to use and comment the others out.

# ------------------------------------------
# OPTION 1: Local Ollama (Recommended for Privacy)
# ------------------------------------------
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=deepseek-r1:32b

# ------------------------------------------
# OPTION 2: Google Gemini via API
# ------------------------------------------
# Get API Key: https://aistudio.google.com/app/apikey
# LLM_PROVIDER=google
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GOOGLE_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-2.5-flash-lite

# ------------------------------------------
# OPTION 3: OpenAI via API
# ------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-tu_clave_de_openai
# LLM_MODEL=gpt-4o-mini

# ==========================================
# PROJECT CONFIGURATION
# ==========================================
DATA_PATH=
