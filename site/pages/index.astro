    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
  }

  .flow-node {
    min-height: 112px;
    padding: 0.9rem;
    border: 2px solid var(--line);
    border-radius: 8px;
    background: #f8fbfa;
  }

  .flow-node span {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .flow-node strong {
    display: block;
    line-height: 1.2;
  }

  .flow-connector {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 112px;
    color: var(--green);
    text-align: center;
  }

  .flow-connector::before,
  .flow-connector::after {
    content: "";
    position: absolute;
    top: 50%;
    z-index: 0;
    display: block;
  }

  .flow-connector::before {
    left: 4px;
    right: 14px;
    height: 2px;
    background: currentColor;
  }

  .flow-connector::after {
    right: 4px;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-block: 6px solid transparent;
    border-left: 9px solid currentColor;
    background: transparent;
  }

  .flow-connector strong {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    min-height: 32px;
    margin: 0.35rem 0;
    z-index: 1;
    color: white;
    background: var(--green);
    border-radius: 999px;
    font-size: 0.78rem;
  }

  .flow-connector span {
    max-width: 120px;
    z-index: 1;
    padding: 0.12rem 0.28rem;
    color: var(--muted);
    background: #f8fbfa;
    font-size: 0.76rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .flow-connector.dashed::before {
    background: repeating-linear-gradient(90deg, currentColor 0 7px, transparent 7px 12px);
  }

  .flow-connector.bidirectional::after {
    content: "↔";
    top: 50%;
    right: 50%;
    width: auto;
    height: auto;
    border: 0;
    background: #f8fbfa;
    font-size: 1.2rem;
    font-weight: 900;
    transform: translate(50%, -50%);
  }

  .flow-connector.merge strong {
    background: var(--blue);
  }

  .flow-connector.cycle strong {
    background: #7c5a0d;
  }

