                  <tr><td>Qwen</td><td>Qwen 3.5 122B</td><td>122B</td><td>Disponible en FMS abierto de Databricks.</td></tr>
                  <tr><td>Open weights</td><td>GPT OSS 120B</td><td>120B</td><td>Disponible en FMS abierto de Databricks.</td></tr>
                </tbody>
              </table>
            </div>

            <h4>Requerimiento de GPU aproximado</h4>
            <div class="table-wrap compact-table">
              <table>
                <thead><tr><th>Tamaño de modelo</th><th>GPU mínima práctica</th><th>Recomendación</th></tr></thead>
                <tbody>
                  <tr><td>32B 4-bit</td><td>A100 80 GB o GPU equivalente con margen</td><td>T4 no recomendada</td></tr>
                  <tr><td>32B con contexto largo</td><td>A100 80 GB</td><td>Mejor margen para KV cache</td></tr>
                  <tr><td>70B 4-bit</td><td>A100 80 GB mínimo razonable</td><td>Puede requerir optimización fuerte</td></tr>
                  <tr><td>70B+ con serving</td><td>varias GPU o Model Serving</td><td>no incluir en MVP</td></tr>
