  .flow-lane {
    position: relative;
    display: grid;
    grid-template-columns:
      minmax(120px, 0.55fr)
      minmax(170px, 1fr)
      minmax(90px, 0.42fr)
      minmax(170px, 1fr)
      minmax(90px, 0.42fr)
      minmax(170px, 1fr)
      minmax(90px, 0.42fr)
      minmax(170px, 1fr);
    gap: 0.75rem;
    align-items: stretch;
    min-width: 1160px;
    padding: 0.8rem;
    background: #f8fbfa;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .lane-label {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem;
