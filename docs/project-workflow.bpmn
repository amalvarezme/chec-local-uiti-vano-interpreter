<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_chec_pipeline"
                   targetNamespace="http://chec.local/uiti-vano/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_chec" name="CHEC — Local UITI_VANO Interpreter Pipeline" processRef="Process_chec_pipeline" />
  </bpmn:collaboration>
  <bpmn:process id="Process_chec_pipeline" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
    <bpmn:lane id="lane1" name="Data ingestion">
      <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw_split</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_pdf</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_climate</bpmn:flowNodeRef>
    </bpmn:lane>
    <bpmn:lane id="lane2" name="ML modeling — M-GCECDL">
      <bpmn:flowNodeRef>t_graph</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_optuna</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_train</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw_model</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_perf</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_shap</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_docrep</bpmn:flowNodeRef>
    </bpmn:lane>
    <bpmn:lane id="lane3" name="Local interpretation — LLM agents">
      <bpmn:flowNodeRef>t_crit</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_ctx</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_checkpoint</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw_check</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>end_invalid</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_prepare</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw_fork</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_historical</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_inference</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_autosim</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw1</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_retry</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>end_stop1</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw_autosim</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_retry_auto</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_skip_auto</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw_autosim_merge</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw_join</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_expert_prep</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_expert_agent</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>gw2</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_retry2</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>end_stop2</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_render</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>end_report</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_whatif</bpmn:flowNodeRef>
    </bpmn:lane>
    <bpmn:lane id="lane4" name="Publication">
      <bpmn:flowNodeRef>t_publish</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_export</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>t_ci</bpmn:flowNodeRef>
      <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
    </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:parallelGateway id="gw_split">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="t_pdf" name="Extraer tabla de discusion de PDFs expertos (pdf-discussion-extraction, runbook por lotes)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_climate" name="Enriquecimiento climatico (Open-Meteo API)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_graph" name="Construccion de grafo experto (adjacency)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_optuna" name="Busqueda de hiperparametros (Optuna)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_train" name="Entrenamiento M-GCECDL (Colab GPU)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:outgoing>Flow_p1</bpmn:outgoing>
      <bpmn:outgoing>Flow_wf1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="gw_model">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="t_perf" name="Evaluacion de desempeno">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_shap" name="Analisis SHAP por circuito">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_docrep" name="Replicacion de documento">
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="t_crit" name="Deteccion de puntos criticos">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_ctx" name="Construccion de contexto estructurado">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="t_checkpoint" name="Checkpoint unico: confirmar circuito + ventana de fechas">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_ck1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_check">
      <bpmn:incoming>Flow_ck1</bpmn:incoming>
      <bpmn:outgoing>Flow_ck2</bpmn:outgoing>
      <bpmn:outgoing>Flow_ck3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_invalid" name="Alertar y detener (sin run_dir)">
      <bpmn:incoming>Flow_ck2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t_prepare" name="prepare(): puntos criticos + contexto + simulador MGCECDL/SHAP + simulador automatico minimo/maximo">
      <bpmn:incoming>Flow_ck3</bpmn:incoming>
      <bpmn:incoming>Flow_p1</bpmn:incoming>
      <bpmn:outgoing>Flow_p2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="gw_fork">
      <bpmn:incoming>Flow_p2</bpmn:incoming>
      <bpmn:outgoing>Flow_f1</bpmn:outgoing>
      <bpmn:outgoing>Flow_f2</bpmn:outgoing>
      <bpmn:outgoing>Flow_f3</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="t_historical" name="Agente historical (paralelo)">
      <bpmn:incoming>Flow_f1</bpmn:incoming>
      <bpmn:outgoing>Flow_g1a</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_inference" name="Agente inference (paralelo)">
      <bpmn:incoming>Flow_f2</bpmn:incoming>
      <bpmn:outgoing>Flow_g1b</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_autosim" name="Agente auto-simulator (paralelo, degrade-on-fail)">
      <bpmn:incoming>Flow_f3</bpmn:incoming>
      <bpmn:outgoing>Flow_a1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gw1" name="Schema + provenance validos? (historical + inference)">
      <bpmn:incoming>Flow_g1a</bpmn:incoming>
      <bpmn:incoming>Flow_g1b</bpmn:incoming>
      <bpmn:incoming>Flow_r2</bpmn:incoming>
      <bpmn:outgoing>Flow_r1</bpmn:outgoing>
      <bpmn:outgoing>Flow_s1</bpmn:outgoing>
      <bpmn:outgoing>Flow_j1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_retry" name="Revisar respuesta (max. 2 reintentos)">
      <bpmn:incoming>Flow_r1</bpmn:incoming>
      <bpmn:outgoing>Flow_r2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end_stop1" name="Detener ejecucion del circuito">
      <bpmn:incoming>Flow_s1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="gw_autosim" name="validate() ok? (auto-simulator)">
      <bpmn:incoming>Flow_a1</bpmn:incoming>
      <bpmn:incoming>Flow_ar2</bpmn:incoming>
      <bpmn:outgoing>Flow_ar1</bpmn:outgoing>
      <bpmn:outgoing>Flow_as1</bpmn:outgoing>
      <bpmn:outgoing>Flow_aj1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_retry_auto" name="Revisar respuesta auto-simulator (max. 2 reintentos)">
      <bpmn:incoming>Flow_ar1</bpmn:incoming>
      <bpmn:outgoing>Flow_ar2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_skip_auto" name="Omitir auto-simulator (degradacion, no detiene la ejecucion)">
      <bpmn:incoming>Flow_as1</bpmn:incoming>
      <bpmn:outgoing>Flow_aj2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gw_autosim_merge">
      <bpmn:incoming>Flow_aj1</bpmn:incoming>
      <bpmn:incoming>Flow_aj2</bpmn:incoming>
      <bpmn:outgoing>Flow_aj3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="gw_join">
      <bpmn:incoming>Flow_j1</bpmn:incoming>
      <bpmn:incoming>Flow_aj3</bpmn:incoming>
      <bpmn:outgoing>Flow_j2</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="t_expert_prep" name="prepare_expert_alignment()">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:incoming>Flow_j2</bpmn:incoming>
      <bpmn:outgoing>Flow_e1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_expert_agent" name="Agente expert-alignment">
      <bpmn:incoming>Flow_e1</bpmn:incoming>
      <bpmn:outgoing>Flow_e2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gw2" name="Schema + provenance validos?">
      <bpmn:incoming>Flow_e2</bpmn:incoming>
      <bpmn:incoming>Flow_er2</bpmn:incoming>
      <bpmn:outgoing>Flow_er1</bpmn:outgoing>
      <bpmn:outgoing>Flow_es1</bpmn:outgoing>
      <bpmn:outgoing>Flow_ev1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_retry2" name="Revisar respuesta (max. 2 reintentos)">
      <bpmn:incoming>Flow_er1</bpmn:incoming>
      <bpmn:outgoing>Flow_er2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end_stop2" name="Detener ejecucion del circuito">
      <bpmn:incoming>Flow_es1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t_render" name="render(): fusiona historical + inference + auto-simulator (si disponible) + expert-alignment en un unico HTML">
      <bpmn:incoming>Flow_ev1</bpmn:incoming>
      <bpmn:outgoing>Flow_rr1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end_report" name="Reporte HTML generado (run_dir, local)">
      <bpmn:incoming>Flow_rr1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t_whatif" name="Simulador what-if interactivo (core/04_simulador.ipynb, sin LLM)">
      <bpmn:incoming>Flow_wf1</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="t_publish" name="Publicacion manual del reporte (web_export.export_latest_interpretability_report) - accion deliberada, no automatica">
      <bpmn:outgoing>Flow_pub2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_export" name="Exportacion web (web_export.py)">
      <bpmn:incoming>Flow_pub2</bpmn:incoming>
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:outgoing>Flow_28</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_ci" name="GitHub Actions (deploy-pages.yml)">
      <bpmn:incoming>Flow_28</bpmn:incoming>
      <bpmn:outgoing>Flow_29</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end" name="GitHub Pages publicado">
      <bpmn:incoming>Flow_29</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="start" targetRef="gw_split" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="gw_split" targetRef="t_pdf" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="gw_split" targetRef="t_climate" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="gw_split" targetRef="t_graph" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="gw_split" targetRef="t_crit" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="t_climate" targetRef="t_optuna" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="t_optuna" targetRef="t_train" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="t_graph" targetRef="t_train" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="t_train" targetRef="gw_model" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="gw_model" targetRef="t_perf" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="gw_model" targetRef="t_shap" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="gw_model" targetRef="t_docrep" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="t_crit" targetRef="t_ctx" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="t_train" targetRef="t_ctx" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="t_ctx" targetRef="t_checkpoint" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="t_pdf" targetRef="t_expert_prep" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="t_shap" targetRef="t_expert_prep" />
    <bpmn:sequenceFlow id="Flow_ck1" sourceRef="t_checkpoint" targetRef="gw_check" />
    <bpmn:sequenceFlow id="Flow_ck2" name="circuito no encontrado / cero eventos" sourceRef="gw_check" targetRef="end_invalid" />
    <bpmn:sequenceFlow id="Flow_ck3" name="confirmado (checkpoint unico)" sourceRef="gw_check" targetRef="t_prepare" />
    <bpmn:sequenceFlow id="Flow_p1" sourceRef="t_train" targetRef="t_prepare" />
    <bpmn:sequenceFlow id="Flow_p2" sourceRef="t_prepare" targetRef="gw_fork" />
    <bpmn:sequenceFlow id="Flow_f1" sourceRef="gw_fork" targetRef="t_historical" />
    <bpmn:sequenceFlow id="Flow_f2" sourceRef="gw_fork" targetRef="t_inference" />
    <bpmn:sequenceFlow id="Flow_f3" sourceRef="gw_fork" targetRef="t_autosim" />
    <bpmn:sequenceFlow id="Flow_g1a" sourceRef="t_historical" targetRef="gw1" />
    <bpmn:sequenceFlow id="Flow_g1b" sourceRef="t_inference" targetRef="gw1" />
    <bpmn:sequenceFlow id="Flow_r1" name="no, con reintentos" sourceRef="gw1" targetRef="t_retry" />
    <bpmn:sequenceFlow id="Flow_r2" sourceRef="t_retry" targetRef="gw1" />
    <bpmn:sequenceFlow id="Flow_s1" name="no, reintentos agotados" sourceRef="gw1" targetRef="end_stop1" />
    <bpmn:sequenceFlow id="Flow_j1" name="si, valido" sourceRef="gw1" targetRef="gw_join" />
    <bpmn:sequenceFlow id="Flow_a1" sourceRef="t_autosim" targetRef="gw_autosim" />
    <bpmn:sequenceFlow id="Flow_ar1" name="no, con reintentos" sourceRef="gw_autosim" targetRef="t_retry_auto" />
    <bpmn:sequenceFlow id="Flow_ar2" sourceRef="t_retry_auto" targetRef="gw_autosim" />
    <bpmn:sequenceFlow id="Flow_as1" name="no, reintentos agotados" sourceRef="gw_autosim" targetRef="t_skip_auto" />
    <bpmn:sequenceFlow id="Flow_aj1" name="si, valido" sourceRef="gw_autosim" targetRef="gw_autosim_merge" />
    <bpmn:sequenceFlow id="Flow_aj2" sourceRef="t_skip_auto" targetRef="gw_autosim_merge" />
    <bpmn:sequenceFlow id="Flow_aj3" sourceRef="gw_autosim_merge" targetRef="gw_join" />
    <bpmn:sequenceFlow id="Flow_j2" sourceRef="gw_join" targetRef="t_expert_prep" />
    <bpmn:sequenceFlow id="Flow_e1" sourceRef="t_expert_prep" targetRef="t_expert_agent" />
    <bpmn:sequenceFlow id="Flow_e2" sourceRef="t_expert_agent" targetRef="gw2" />
    <bpmn:sequenceFlow id="Flow_er1" name="no, con reintentos" sourceRef="gw2" targetRef="t_retry2" />
    <bpmn:sequenceFlow id="Flow_er2" sourceRef="t_retry2" targetRef="gw2" />
    <bpmn:sequenceFlow id="Flow_es1" name="no, reintentos agotados" sourceRef="gw2" targetRef="end_stop2" />
    <bpmn:sequenceFlow id="Flow_ev1" name="si, valido" sourceRef="gw2" targetRef="t_render" />
    <bpmn:sequenceFlow id="Flow_rr1" sourceRef="t_render" targetRef="end_report" />
    <bpmn:sequenceFlow id="Flow_wf1" sourceRef="t_train" targetRef="t_whatif" />
    <bpmn:association id="Flow_pub1" sourceRef="end_report" targetRef="t_publish" />
    <bpmn:sequenceFlow id="Flow_pub2" sourceRef="t_publish" targetRef="t_export" />
    <bpmn:sequenceFlow id="Flow_25" sourceRef="t_perf" targetRef="t_export" />
    <bpmn:sequenceFlow id="Flow_28" sourceRef="t_export" targetRef="t_ci" />
    <bpmn:sequenceFlow id="Flow_29" sourceRef="t_ci" targetRef="end" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_chec_di" bpmnElement="Participant_chec" isHorizontal="true">
        <dc:Bounds x="0" y="20.0" width="4116.0" height="1310.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane1_di" bpmnElement="lane1" isHorizontal="true">
        <dc:Bounds x="40.0" y="50.0" width="4036.0" height="220.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane2_di" bpmnElement="lane2" isHorizontal="true">
        <dc:Bounds x="40.0" y="270.0" width="4036.0" height="260.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane3_di" bpmnElement="lane3" isHorizontal="true">
        <dc:Bounds x="40.0" y="530.0" width="4036.0" height="500.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane4_di" bpmnElement="lane4" isHorizontal="true">
        <dc:Bounds x="40.0" y="1030.0" width="4036.0" height="240.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="252.0" y="142.0" width="36.0" height="36.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_split_di" bpmnElement="gw_split">
        <dc:Bounds x="398.0" y="138.0" width="44.0" height="44.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_pdf_di" bpmnElement="t_pdf">
        <dc:Bounds x="470.0" y="128.0" width="180" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_climate_di" bpmnElement="t_climate">
        <dc:Bounds x="690.0" y="128.0" width="160.0" height="64.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_graph_di" bpmnElement="t_graph">
        <dc:Bounds x="470.0" y="288.0" width="160.0" height="64.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_optuna_di" bpmnElement="t_optuna">
