  h2 {
    margin-bottom: 0.8rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  .lead,
  .section-heading p {
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.16rem);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.15rem;
    border: 1px solid var(--green);
    border-radius: 6px;
    font-weight: 800;
  }

  .button.primary {
    color: white;
    background: var(--green);
  }

  .button.secondary {
    color: var(--green-dark);
    background: white;
  }

  .hero-panel {
    padding: clamp(1.25rem, 3vw, 2rem);
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .panel-logo {
    width: min(260px, 100%);
    margin-bottom: 1.5rem;
  }

  dl {
    display: grid;
    gap: 0.85rem;
    margin: 0;
  }

  dl div {
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--line);
  }

  dl div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  dt {
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  dd {
    margin: 0.2rem 0 0;
    font-size: 1.08rem;
    font-weight: 800;
  }

  .logo-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 8vw, 6rem);
    width: 100%;
    padding: 2rem 1rem;
    background: white;
    border-block: 1px solid var(--line);
  }

  .logo-strip img {
    max-width: 180px;
    max-height: 78px;
    object-fit: contain;
  }

  .section {
    padding: clamp(3.2rem, 8vw, 6rem) 0;
  }

  .section.tinted {
    width: 100%;
    padding-inline: max(1rem, calc((100% - 1120px) / 2));
    background: #edf5f2;
    border-block: 1px solid var(--line);
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .section-heading.compact {
    margin-bottom: 1.2rem;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .summary-grid article,
  .deliverable-grid article {
    min-height: 100%;
    padding: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 10px 28px rgb(16 33 41 / 6%);
  }

  .summary-grid span {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--blue);
    font-weight: 900;
  }

  .summary-grid p,
  .deliverable-grid p,
  .timeline p,
  figcaption,
  footer p {
    color: var(--muted);
    line-height: 1.55;
  }

  .table-wrap {
    overflow-x: auto;
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
  }

  th,
  td {
    padding: 1rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--line);
  }

  th {
    color: var(--green-dark);
    background: #f8fbfa;
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  tr:last-child td {
    border-bottom: 0;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0.28rem 0.65rem;
    color: #684308;
    background: #fff3d9;
    border: 1px solid #f7cf83;
    border-radius: 999px;
    font-size: 0.86rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .timeline {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .timeline article {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1.15rem;
    background: white;
    border-left: 4px solid var(--green);
    border-radius: 8px;
  }

  .timeline strong {
    color: var(--gold);
    font-size: 1.2rem;
  }

  .deliverable-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .results figure {
    margin: 0;
    padding: clamp(0.7rem, 2vw, 1rem);
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .results img {
    width: 100%;
    border-radius: 6px;
  }

  figcaption {
    margin-top: 0.8rem;
    font-size: 0.95rem;
  }

  .cloud {
    padding-top: clamp(2rem, 5vw, 4rem);
  }

  .cloud-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: clamp(1.2rem, 4vw, 2.5rem);
    align-items: start;
  }

  .cloud-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
    color: white;
    background: #ff3621;
    border: 1px solid #cf2d1d;
    border-radius: 6px;
    font-weight: 800;
  }

  .cloud-items {
    display: grid;
    gap: 0.85rem;
  }

  .cloud-items article {
    padding: 1rem;
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .cloud-items p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .cloud-visuals {
    display: grid;
    gap: 1rem;
    padding: clamp(0.8rem, 2vw, 1rem);
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .databricks-mark {
    width: min(180px, 100%);
    max-height: 70px;
    object-fit: contain;
  }

  .engine-figure {
    width: 100%;
    border-radius: 6px;
    border: 1px solid var(--line);
  }

  .prototype {
    width: 100%;
    padding-inline: max(1rem, calc((100% - 1120px) / 2));
    background: linear-gradient(180deg, #f8fbfa 0%, #eef6f3 100%);
    border-top: 1px solid var(--line);
  }

  .prototype-showcase {
    display: grid;
    gap: 1rem;
  }

  .feature-shot {
    display: grid;
    grid-template-columns: minmax(280px, 0.45fr) minmax(0, 0.55fr);
    gap: clamp(1rem, 3vw, 1.6rem);
    align-items: center;
    padding: clamp(1rem, 3vw, 1.4rem);
    color: white;
    background: linear-gradient(135deg, #10352e 0%, #0b5f8a 100%);
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .feature-shot span {
    display: inline-flex;
    margin-bottom: 0.7rem;
    color: #ffe2a6;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .feature-shot h3 {
    max-width: 420px;
    margin-bottom: 0.7rem;
    font-size: clamp(1.5rem, 3vw, 2.35rem);
    line-height: 1.05;
  }

  .feature-shot p {
    margin-bottom: 0;
    color: rgb(255 255 255 / 82%);
    line-height: 1.6;
  }

  .feature-shot img {
    width: 100%;
    border: 1px solid rgb(255 255 255 / 20%);
    border-radius: 6px;
    box-shadow: 0 18px 44px rgb(0 0 0 / 20%);
  }

  .prototype-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .prototype-gallery article {
    overflow: hidden;
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 12px 32px rgb(16 33 41 / 8%);
  }

  .prototype-gallery img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
  }

  .prototype-gallery div {
    padding: 1rem;
  }

  .prototype-gallery p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .physics {
    width: 100%;
    padding-inline: max(1rem, calc((100% - 1120px) / 2));
    background: white;
    border-top: 1px solid var(--line);
  }

  .physics-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .physics-summary article {
    padding: 1.1rem;
    background: #f8fbfa;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .physics-summary p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .physics-table {
    margin-bottom: 1.2rem;
  }

  .modes-table td:nth-child(2),
  .modes-table th:nth-child(2) {
    width: 170px;
    text-align: center;
  }

  .connection-intro {
    max-width: 760px;
    margin: 2rem 0 1rem;
  }

  .connection-intro p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .connections-table table {
    min-width: 980px;
  }

  .graph-banner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    margin: 1.2rem 0;
    padding: clamp(1rem, 3vw, 1.4rem);
    color: white;
    background: linear-gradient(135deg, #0b5f8a 0%, #007a53 100%);
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .graph-banner span {
    display: inline-flex;
    margin-bottom: 0.55rem;
    color: #ffe2a6;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .graph-banner h3 {
    max-width: 680px;
    margin-bottom: 0.45rem;
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    line-height: 1.1;
  }

  .graph-banner p {
    margin-bottom: 0;
    color: rgb(255 255 255 / 82%);
    line-height: 1.55;
  }

  .graph-banner a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1rem;
    color: var(--green-dark);
    background: white;
    border-radius: 6px;
    font-weight: 900;
    white-space: nowrap;
  }

  .graph-actions {
    display: flex;
    gap: 0.65rem;
    align-items: stretch;
  }

  .graph-note {
    max-width: 980px;
    margin: 1rem auto 0;
    padding: clamp(1rem, 3vw, 1.4rem);
    color: var(--ink);
    background: #fff7e6;
    border: 1px solid #f3d28c;
    border-left: 5px solid var(--gold);
    border-radius: 8px;
    font-size: clamp(1.05rem, 2vw, 1.28rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .architecture {
    width: 100%;
    padding-inline: max(1rem, calc((100% - 1120px) / 2));
    background: linear-gradient(180deg, #f8fbfa 0%, #ffffff 100%);
    border-top: 1px solid var(--line);
  }

  .architecture-pillars {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .architecture-pillars article,
  .architecture-pillars .pillar-card,
  .agent-grid article,
  .value-cycle article {
    padding: 1rem;
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 10px 28px rgb(16 33 41 / 6%);
  }

  .architecture-pillars span {
    display: inline-flex;
    margin-bottom: 0.65rem;
    color: var(--blue);
    font-weight: 900;
  }

  .architecture-pillars p,
  .agent-grid p,
  .value-cycle p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .pillar-card {
    display: block;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .pillar-card:hover,
  .pillar-card:focus-visible {
    transform: translateY(-3px);
    border-color: #8bc6b3;
    box-shadow: 0 16px 36px rgb(0 122 83 / 13%);
    outline: none;
  }

  .pillar-card strong {
    display: inline-flex;
    margin-top: 0.9rem;
    color: var(--green-dark);
    font-size: 0.88rem;
  }

  .agent-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .agent-type {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    margin-bottom: 0.75rem;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 900;
  }

  .agent-type.low {
    color: #0a4c63;
    background: #d9edf7;
  }

  .agent-type.high {
    color: #215d2d;
    background: #dff0d8;
  }

  .agent-type.model {
    color: #444;
    background: #e2e2ea;
  }

  .flow-diagram {
    display: grid;
    gap: 1rem;
    margin: 1.4rem 0;
    padding: clamp(1rem, 3vw, 1.4rem);
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
    overflow-x: auto;
  }

  .flow-title {
    max-width: 760px;
  }

  .flow-title p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .flow-lane {
    position: relative;
    display: grid;
    grid-template-columns:
      minmax(120px, 0.55fr)
      minmax(170px, 1fr)
      minmax(90px, 0.42fr)
      minmax(170px, 1fr)
      minmax(90px, 0.42fr)
      minmax(170px, 1fr)
      minmax(90px, 0.42fr)
      minmax(170px, 1fr);
    gap: 0.75rem;
    align-items: stretch;
    min-width: 1160px;
    padding: 0.8rem;
    background: #f8fbfa;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .lane-label {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem;
    color: var(--green-dark);
    background: white;
    border: 1px solid var(--line);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
  }

  .flow-node {
    min-height: 112px;
    padding: 0.9rem;
    border: 2px solid var(--line);
    border-radius: 8px;
    background: #f8fbfa;
  }

  .flow-node span {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .flow-node strong {
    display: block;
    line-height: 1.2;
  }

  .flow-connector {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 112px;
    color: var(--green);
    text-align: center;
  }

  .flow-connector::before,
  .flow-connector::after {
    content: "";
    position: absolute;
    top: 50%;
    z-index: 0;
    display: block;
  }

  .flow-connector::before {
    left: 4px;
    right: 14px;
    height: 2px;
    background: currentColor;
  }

  .flow-connector::after {
    right: 4px;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-block: 6px solid transparent;
    border-left: 9px solid currentColor;
    background: transparent;
  }

  .flow-connector strong {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    min-height: 32px;
    margin: 0.35rem 0;
    z-index: 1;
    color: white;
    background: var(--green);
    border-radius: 999px;
    font-size: 0.78rem;
  }

  .flow-connector span {
    max-width: 120px;
    z-index: 1;
    padding: 0.12rem 0.28rem;
    color: var(--muted);
    background: #f8fbfa;
    font-size: 0.76rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .flow-connector.dashed::before {
    background: repeating-linear-gradient(90deg, currentColor 0 7px, transparent 7px 12px);
  }

  .flow-connector.bidirectional::after {
    content: "↔";
    top: 50%;
    right: 50%;
    width: auto;
    height: auto;
    border: 0;
    background: #f8fbfa;
    font-size: 1.2rem;
    font-weight: 900;
    transform: translate(50%, -50%);
  }

  .flow-connector.merge strong {
    background: var(--blue);
  }

  .flow-connector.cycle strong {
    background: #7c5a0d;
  }

  .user-node {
    background: #fff5f7;
    border-color: #d8a7b1;
  }

  .agent-low-node {
    background: #edf8fc;
    border-color: #9dc7d7;
  }

  .agent-high-node {
    background: #edf8ec;
    border-color: #9cc99b;
  }

  .data-node,
  .context-node {
    background: #fff9e8;
    border-color: #e2c878;
  }

  .doc-node {
    background: #eef7e9;
    border-color: #a6ce96;
  }

  .model-node {
    background: #f1f1f6;
    border-color: #b7b7c5;
    border-style: dashed;
  }

  .output-node {
    background: #fff4d6;
    border-color: #ddb84d;
  }

  .emphasis-node {
    border-width: 3px;
    box-shadow: 0 14px 34px rgb(0 122 83 / 14%);
  }

  .value-cycle {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .value-cycle strong {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--green-dark);
    font-size: 1.05rem;
  }

  .detail-panel {
    position: fixed;
    inset: 0;
    z-index: 100;
    width: 100%;
    overflow-y: auto;
    padding: 1rem;
    background: rgb(243 248 246 / 98%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease, visibility 180ms;
  }

  .detail-panel:target {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .detail-shell {
    width: min(1180px, 100%);
    margin: 0 auto;
    padding: clamp(1.2rem, 4vw, 3rem);
    background: white;
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: 0 26px 80px rgb(16 33 41 / 18%);
  }

  .back-link {
    position: sticky;
    top: 0;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    margin-bottom: 2rem;
    padding: 0.65rem 0.9rem;
    color: white;
    background: var(--green);
    border-radius: 6px;
    font-weight: 900;
    box-shadow: 0 8px 24px rgb(0 92 69 / 20%);
  }

  .back-link.bottom {
    position: static;
    margin: 1rem 0 0;
  }

  .detail-stats,
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
    margin-bottom: 1.4rem;
  }

  .detail-stats article,
  .metrics-grid article {
    padding: 1rem;
    background: #f8fbfa;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .detail-stats strong,
  .metrics-grid strong {
    display: block;
    color: var(--green-dark);
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  .detail-stats span,
  .metrics-grid span {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .detail-block {
    margin-top: 1.2rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    background: white;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 10px 30px rgb(16 33 41 / 6%);
  }

  .detail-block > h3 {
    margin-bottom: 0.7rem;
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  .detail-block > p,
  .detail-block figcaption {
    color: var(--muted);
    line-height: 1.6;
  }

  .wide-table table {
    min-width: 1800px;
    font-size: 0.82rem;
  }

  .compact-table {
    max-height: 520px;
  }

  .compact-table table {
    min-width: 680px;
  }

  .ellipsis-row td {
    color: var(--muted);
    background: #f8fbfa;
    text-align: center;
    font-style: italic;
  }

  .graph-frame {
    width: 100%;
    min-height: 680px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f8fbfa;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .process-grid article {
    padding: 1rem;
    background: #f8fbfa;
    border-left: 4px solid var(--green);
    border-radius: 6px;
  }

  .process-grid strong {
    display: block;
    margin-bottom: 0.45rem;
  }

  .process-grid p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.5;
