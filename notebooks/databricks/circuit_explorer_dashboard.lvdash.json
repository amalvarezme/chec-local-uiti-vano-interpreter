  "pages": [
    {
      "name": "main_page",
      "displayName": "Explorador de circuito",
      "layout": [
        {
          "widget": {
            "name": "header_md",
            "multilineTextboxSpec": {
              "lines": [
                "# CHEC — Explorador de Circuito UITI_VANO\n",
                "Seleccione un circuito para ver su posición de clustering (rango completo), su evolución diaria de UITI_VANO y el mapa de eventos, ambos filtrables por rango de fechas."
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 12,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "circuit_filter",
            "queries": [
              {
                "name": "q_detail",
                "query": {
                  "datasetName": "circuit_detail_ds",
                  "fields": [
                    {
                      "name": "circuito",
                      "expression": "`circuito`"
                    },
                    {
                      "name": "circuito_associativity",
                      "expression": "COUNT_IF(`associative_filter_predicate_group`)"
                    }
                  ],
                  "disaggregated": false
                }
              },
              {
                "name": "q_daily",
                "query": {
                  "datasetName": "daily_line_ds",
                  "fields": [
                    {
                      "name": "circuito",
                      "expression": "`circuito`"
                    },
                    {
                      "name": "circuito_associativity",
                      "expression": "COUNT_IF(`associative_filter_predicate_group`)"
                    }
                  ],
                  "disaggregated": false
                }
              },
              {
                "name": "q_geo",
                "query": {
                  "datasetName": "circuit_map_lines_equipment_ds",
                  "fields": [
                    {
                      "name": "circuito",
                      "expression": "`circuito`"
                    },
                    {
                      "name": "circuito_associativity",
                      "expression": "COUNT_IF(`associative_filter_predicate_group`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Circuito",
                "showTitle": true
              },
              "widgetType": "filter-single-select",
              "encodings": {
                "fields": [
                  {
                    "fieldName": "circuito",
                    "queryName": "q_detail"
                  },
                  {
                    "fieldName": "circuito",
                    "queryName": "q_daily"
                  },
                  {
                    "fieldName": "circuito",
                    "queryName": "q_geo"
                  }
                ]
              }
            }
          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 6,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "date_filter",
            "queries": [
